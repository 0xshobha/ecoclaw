# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── FLock.io  (OpenAI-compatible federated LLM) ──────────────────────────────
FLOCK_API_KEY=your_flock_api_key_here
FLOCK_API_BASE=https://api.flock.io/v1
FLOCK_MODEL=flock-eco-large

# ── Z.AI  (compound AI reasoning) ────────────────────────────────────────────
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_BASE=https://api.z.ai/v1
ZAI_MODEL=z-compound-v1

# ── NASA  (free key from https://api.nasa.gov) ────────────────────────────────
NASA_API_KEY=DEMO_KEY

# ── Compression Company Satellite SDK  (request at hackathon) ────────────────
COMPRESSION_API_KEY=
COMPRESSION_API_BASE=https://api.compressionco.io/v1

# ── Web3 / Animoca  (Base mainnet) ────────────────────────────────────────────
WEB3_RPC_URL=https://mainnet.base.org
WALLET_PRIVATE_KEY=
NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Unibase  (on-chain / BNB Greenfield decentralised storage) ──────────────
UNIBASE_API_KEY=

# ── Virtual Protocol  (agent-NFT / on-chain reputation) ─────────────────────
VIRTUAL_PROTOCOL_API_KEY=
VIRTUAL_PROTOCOL_AGENT_ID=ecoclaw-agent-v1

# ── Telegram Webhook  (optional – leave blank to use long-polling) ───────────
# Set WEBHOOK_URL to your public HTTPS domain to switch bot to webhook mode
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=

# ── Application ───────────────────────────────────────────────────────────────
# Set MOCK_MODE=false when all live API keys are available
MOCK_MODE=true
LOG_LEVEL=INFO
DATA_DIR=data
LOG_DIR=logs
